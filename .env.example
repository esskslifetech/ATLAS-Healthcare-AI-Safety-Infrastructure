# OpenAI API Key (required for AI triage)
OPENAI_API_KEY=sk-your-openai-api-key-here

# FHIR Server Configuration (optional - defaults to demo endpoint)
FHIR_BASE_URL=https://launch.smarthealthit.org/v/r4/fhir
FHIR_TOKEN=your-smart-fhir-token-here

# SMART on FHIR Configuration (optional)
SMART_CLIENT_ID=your-smart-client-id
SMART_CLIENT_SECRET=your-smart-client-secret

# Audit Configuration
AUDIT_RETENTION_DAYS=2555  # 7 years (HIPAA minimum)

# Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info
